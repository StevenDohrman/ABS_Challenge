# ─────────────────────────────────────────────────────────────────────────────
# Database — Supabase (PostgreSQL)
# ─────────────────────────────────────────────────────────────────────────────
#
# DATABASE_URL  → connection pooler (Transaction mode, port 6543).
#                 Used at runtime by Prisma Client.
#                 Required: add ?pgbouncer=true
#
# DIRECT_URL    → direct connection (port 5432).
#                 Used only by `prisma migrate dev` / `prisma migrate deploy`.
#                 Not needed if you're using `prisma db push`.
#
# Find both URLs in:
#   Supabase Dashboard → Project Settings → Database → Connection string
#   Switch to "URI" tab, then toggle between "Session" and "Transaction" modes.
#
# Transaction pooler (DATABASE_URL):
#   postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true
#
# Direct connection (DIRECT_URL):
#   postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
#
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
#
# Optional Prisma pool tuning (appended to DATABASE_URL):
#   connection_limit  → max connections Prisma opens (default: num_cpus*2+1).
#   pool_timeout      → seconds a query waits for a free connection before P2024.
#                       The app auto-applies pool_timeout=20 if you omit it; set
#                       it here to override. Bulk writes are concurrency-capped
#                       (DB_LIMITS.WRITE_CONCURRENCY), so the defaults are fine.
#   e.g. ...:6543/postgres?pgbouncer=true&connection_limit=17&pool_timeout=20

# ─────────────────────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────────────────────
PORT=3001

# ─────────────────────────────────────────────────────────────────────────────
# Data retention
# ─────────────────────────────────────────────────────────────────────────────
# Number of days to retain game data (snapshots, pitch events, recommendations).
# Games older than this are purged at startup and once every 24 hours.
# player_stat_snapshots are never purged (they are per-player per-season).
DATA_RETENTION_DAYS=7
