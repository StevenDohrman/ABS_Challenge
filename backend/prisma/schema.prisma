// Prisma schema for the Strike Zone Challenge Recommendation System.
//
// Table responsibilities:
//   games                     — One row per MLB game; tracks metadata and challenge counts.
//   live_game_snapshots        — Game state at the start of each new at-bat.
//   live_pitch_events          — Every pitch emitted by the MLB live feed, deduplicated.
//   player_stat_snapshots      — Daily Savant batter metrics; one row per player per season.
//   challenge_recommendations  — Engine output pre-computed for every count state per at-bat.
//
// All data flows from MLB Live API and Baseball Savant only. No user input enters
// the recommendation system.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime connection — Supabase transaction pooler (pgBouncer, port 6543).
  url      = env("DATABASE_URL")
  // Migrations only — direct/session connection (port 5432). prisma migrate
  // cannot run through the transaction pooler (it takes an advisory lock and
  // runs DDL that pgBouncer's transaction mode does not support), so it must use
  // this URL instead or it hangs.
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// games
// ─────────────────────────────────────────────────────────────────────────────

model Game {
  id     Int @id @default(autoincrement())
  gamePk Int @unique

  gameDate   String // YYYY-MM-DD official MLB game date
  homeTeamId Int
  awayTeamId Int
  status     String // "Preview" | "Live" | "Final" — mirrors MLB abstractGameState

  // Challenge resources remaining for each team. Each team starts with 2 under
  // ABS rules; a successful (overturned) challenge is retained, so only failed
  // challenges consume the allotment. Derived from review pitch events by
  // recomputeChallengesRemaining; never goes below zero.
  homeChallengesRemaining Int @default(2)
  awayChallengesRemaining Int @default(2)

  // Postgame challenge audit (Phase 5) — runs shortly after Final using MLB live feed pitchData.
  postgameAuditedAt DateTime?
  /** When the game was marked Final. */
  finalizedAt       DateTime?
  /** Live or backfill ingest complete — skip re-fetching the archived feed. */
  ingestedAt        DateTime?
  /** Base/runner/score snapshots repaired from archived feed matchup data. */
  baseStateRepairedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  snapshots       LiveGameSnapshot[]
  pitchEvents     LivePitchEvent[]
  recommendations ChallengeRecommendation[]
  savantPitches   SavantPitchEvent[]
  postgameAudits  PostgameChallengeAudit[]
  lineups         GameLineup[]

  @@map("games")
}

// ─────────────────────────────────────────────────────────────────────────────
// live_game_snapshots
// ─────────────────────────────────────────────────────────────────────────────

// Stores the game state at the start of each new at-bat.
// Written by the backend when the LivePollJob emits an `atBatStart` event.
// One row per at-bat; updated if the same at-bat index is seen again.
model LiveGameSnapshot {
  id            Int    @id @default(autoincrement())
  gamePk        Int
  atBatIndex    Int
  inning        Int
  halfInning    String // "top" | "bottom"
  outs          Int
  runnerOnFirst  Boolean
  runnerOnSecond Boolean
  runnerOnThird  Boolean
  runnerFirstId  Int?
  runnerSecondId Int?
  runnerThirdId  Int?
  homeScore     Int
  awayScore     Int
  batterId      Int
  pitcherId     Int
  battingTeamId  Int
  fieldingTeamId Int
  fetchedAt     DateTime

  // Full MlbAtBatSnapshot object preserved for debugging and reprocessing.
  rawPayload Json

  game Game @relation(fields: [gamePk], references: [gamePk])

  @@unique([gamePk, atBatIndex])
  @@index([gamePk])
  @@map("live_game_snapshots")
}

// ─────────────────────────────────────────────────────────────────────────────
// live_pitch_events
// ─────────────────────────────────────────────────────────────────────────────

// Stores every pitch emitted by the MLB live feed.
// Deduplicated by playId when available; falls back to (gamePk, atBatIndex, pitchNumber).
model LivePitchEvent {
  id          Int     @id @default(autoincrement())
  gamePk      Int
  playId      String? @unique // MLB play UUID; null for older feed versions
  atBatIndex  Int
  pitchNumber Int
  inning      Int
  halfInning  String

  // Count BEFORE this pitch (used to look up the pre-computed recommendation).
  ballsBefore   Int
  strikesBefore Int

  // Count AFTER this pitch (as recorded by the MLB API).
  balls   Int
  strikes Int
  outs    Int

  batterId  Int
  pitcherId Int

  callCode        String? // e.g. "C" for called strike, "B" for ball
  callDescription String? // e.g. "Called Strike", "Ball"

  // ABS challenge review data — populated when the pitch triggered a manager/batter challenge.
  hasReview        Boolean  @default(false)
  isOverturned     Boolean?
  challengerName   String?
  challengerTeamId Int?

  // Plate location from MLB live feed pitchData (postgame audit source).
  plateX            Float?
  plateZ            Float?
  strikeZoneTop     Float?
  strikeZoneBottom  Float?
  mlbZone           Int?

  fetchedAt DateTime

  // Raw MlbPlayEvent object preserved for debugging and future field additions.
  rawPayload Json

  game            Game                      @relation(fields: [gamePk], references: [gamePk])
  recommendations ChallengeRecommendation[]
  postgameAudit   PostgameChallengeAudit?

  @@unique([gamePk, atBatIndex, pitchNumber])
  @@index([gamePk])
  @@map("live_pitch_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// player_stat_snapshots
// ─────────────────────────────────────────────────────────────────────────────

// Daily Savant batter metrics ingested by SavantDailyJob.
// One row per player per season; upserted on each daily run.
//
// Plate discipline fields (kPercent, bbPercent, chasePercent, whiffPercent, zonePercent)
// are stored as percentages (0–100) matching the Savant leaderboard format.
// The backend service divides by 100 before passing them to the engine as rates (0–1).
model PlayerStatSnapshot {
  id         Int    @id @default(autoincrement())
  playerId   Int
  playerName String
  season     Int

  // Batter stance — populated from the MLB Stats API (not Savant).
  // Null until enriched. The engine handles null gracefully (no handedness adjustment).
  battingHand String? // "L" | "R" | "S"

  // Plate appearances sampled from.
  pa Int

  // Traditional stats (Savant leaderboard).
  ba  Float? // batting average
  obp Float? // on-base percentage — from MLB Stats API
  slg Float? // slugging percentage
  ops Float? // OBP + SLG — from MLB Stats API

  // Expected / model-derived metrics.
  woba  Float? // weighted on-base average
  xba   Float? // expected batting average
  xslg  Float? // expected slugging
  xwoba Float? // expected wOBA

  // Plate discipline percentages (0–100 as stored by Savant).
  kPercent     Float? // strikeout rate %
  bbPercent    Float? // walk rate %
  chasePercent Float? // out-of-zone swing % (oz_swing_percent)
  whiffPercent Float? // whiff %
  zonePercent  Float? // in-zone swing %

  // Contact quality.
  hardHitPercent Float?
  barrelPercent  Float?

  // Historical challenge accuracy derived from challenge_recommendations
  // joined with postgame Savant audit data (Phase 5).
  historicalChallengeAttempts    Int   @default(0)
  historicalChallengeSuccessRate Float? // null when no challenge history exists

  fetchedAt DateTime
  updatedAt DateTime @updatedAt

  @@unique([playerId, season])
  @@index([playerId])
  @@map("player_stat_snapshots")
}

// ─────────────────────────────────────────────────────────────────────────────
// challenge_recommendations
// ─────────────────────────────────────────────────────────────────────────────

// Engine output pre-computed for all 12 count states when a new at-bat starts.
// One row per (gamePk, atBatIndex, balls, strikes).
//
// triggeredAt is set when a called-strike pitch event matches this count state,
// making it the "active" recommendation the frontend should display.
model ChallengeRecommendation {
  id         Int @id @default(autoincrement())
  gamePk     Int
  atBatIndex Int

  // Count BEFORE the pitch that would be challenged.
  balls   Int
  strikes Int

  // Engine output fields.
  recommendation            String  // "AUTO_ALLOW" | "ALLOW" | "WARN" | "DENY"
  minimumConfidenceRequired Int     // 0–100 confidence the player must report
  expectedValue             Float   // situation-adjusted EV in runs
  score                     Float   // 0–100 composite score

  // Whether the batting team could physically challenge this at-bat (had at least
  // one challenge available). The recommendation above is value-based regardless;
  // false here means "would be worth it, but the team is out of challenges" — a
  // missed-opportunity signal for the UI and post-game audit.
  challengeAvailable Boolean @default(true)

  // Ordered list of human-readable sentences from the engine.
  explanationJson Json // string[]

  createdAt DateTime @default(now())

  // Set when a called-strike pitch with this count arrives.
  // Null for pre-computed rows that were never triggered.
  triggeredAt  DateTime?
  pitchEventId Int?

  game          Game                     @relation(fields: [gamePk], references: [gamePk])
  pitchEvent    LivePitchEvent?          @relation(fields: [pitchEventId], references: [id])
  postgameAudit PostgameChallengeAudit?

  @@unique([gamePk, atBatIndex, balls, strikes])
  @@index([gamePk, triggeredAt])
  @@map("challenge_recommendations")
}

// ─────────────────────────────────────────────────────────────────────────────
// savant_pitch_events
// ─────────────────────────────────────────────────────────────────────────────

// Postgame Statcast pitch rows keyed by Savant's at_bat_number (1-based).
model SavantPitchEvent {
  id          Int @id @default(autoincrement())
  gamePk      Int
  atBatNumber Int
  atBatIndex  Int
  pitchNumber Int

  batterId  Int
  pitcherId Int

  plateX  Float?
  plateZ  Float?
  szTop   Float?
  szBot   Float?
  zone    Int?
  description String?

  fetchedAt DateTime

  rawPayload Json

  game         Game @relation(fields: [gamePk], references: [gamePk])

  @@unique([gamePk, atBatNumber, pitchNumber])
  @@index([gamePk, atBatIndex, pitchNumber])
  @@map("savant_pitch_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// postgame_challenge_audits
// ─────────────────────────────────────────────────────────────────────────────

// One row per auditable pitch (batting called-strike or fielding called-ball).
model PostgameChallengeAudit {
  id         Int @id @default(autoincrement())
  gamePk     Int
  atBatIndex Int
  pitchNumber Int

  pitchEventId     Int  @unique
  recommendationId Int? @unique
  challengeSide    String @default("batting") // "batting" | "fielding"

  inning     Int
  halfInning String
  balls      Int
  strikes    Int
  outs       Int

  batterId  Int
  pitcherId Int

  originalCall String // "ball" | "strike" | "unknown"

  plateX Float?
  plateZ Float?
  szTop  Float?
  szBot  Float?

  zoneResult String // "ball" | "strike" | "unknown"
  callWasProbablyWrong Boolean

  liveRecommendation String // AUTO_ALLOW | ALLOW | WARN | DENY
  playerConfidence   Int?
  challengeAvailable Boolean

  shouldHaveChallenged Boolean
  missedChallenge      Boolean
  badChallengeAllowed  Boolean

  runExpectancySwing Float
  notesJson          Json // string[]

  createdAt DateTime @default(now())

  game             Game                    @relation(fields: [gamePk], references: [gamePk])
  pitchEvent     LivePitchEvent           @relation(fields: [pitchEventId], references: [id])
  recommendation ChallengeRecommendation? @relation(fields: [recommendationId], references: [id])

  @@index([gamePk, missedChallenge])
  @@index([gamePk, runExpectancySwing])
  @@map("postgame_challenge_audits")
}

// ─────────────────────────────────────────────────────────────────────────────
// player_spray_profiles
// ─────────────────────────────────────────────────────────────────────────────

// Batter batted-ball spray profile. Ingested by SavantDailyJob.
// One row per (playerId, season); upserted on each daily run.
model PlayerSprayProfile {
  id         Int    @id @default(autoincrement())
  playerId   Int
  playerName String
  season     Int

  pa Int

  // Directional tendencies (0–100 as stored by Savant).
  pullPercent        Float?
  straightawayPercent Float?
  oppoPercent        Float?

  // Batted-ball type mix (0–100).
  gbPercent Float?
  fbPercent Float?
  ldPercent Float?

  fetchedAt DateTime
  updatedAt DateTime @updatedAt

  @@unique([playerId, season])
  @@index([playerId])
  @@map("player_spray_profiles")
}

// ─────────────────────────────────────────────────────────────────────────────
// fielder_oaa
// ─────────────────────────────────────────────────────────────────────────────

// Fielder Outs Above Average by position. Ingested by SavantDailyJob.
// One row per (playerId, season, position); upserted on each daily run.
model FielderOaa {
  id         Int    @id @default(autoincrement())
  playerId   Int
  playerName String
  season     Int

  // Fielding position abbreviation: "1B", "2B", "3B", "SS", "LF", "CF", "RF".
  position String

  oaa      Float?
  oaaVsRhh Float?
  oaaVsLhh Float?

  fetchedAt DateTime
  updatedAt DateTime @updatedAt

  @@unique([playerId, season, position])
  @@index([playerId])
  @@map("fielder_oaa")
}

// ─────────────────────────────────────────────────────────────────────────────
// player_sprint_speed
// ─────────────────────────────────────────────────────────────────────────────

// Statcast sprint speed leaderboard. Ingested by SavantDailyJob.
// One row per (playerId, season); upserted on each daily run.
model PlayerSprintSpeed {
  id              Int    @id @default(autoincrement())
  playerId        Int
  playerName      String
  season          Int
  position        String
  sprintSpeed     Float?
  homeTo1b        Float?
  competitiveRuns Int    @default(0)
  fetchedAt       DateTime
  updatedAt       DateTime @updatedAt

  @@unique([playerId, season])
  @@index([playerId])
  @@map("player_sprint_speed")
}

// ─────────────────────────────────────────────────────────────────────────────
// league_averages_snapshots
// ─────────────────────────────────────────────────────────────────────────────

// Season-level league baselines computed from daily Savant + MLB Stats API pulls.
// One row per season; upserted on each SavantDailyJob run.
model LeagueAveragesSnapshot {
  id                 Int      @id @default(autoincrement())
  season             Int      @unique
  chaseRate          Float
  walkRate           Float
  strikeoutRate      Float
  whiffRate          Float
  ops                Float
  woba               Float
  gbRate             Float
  fbRate             Float
  ldRate             Float
  pullRate           Float
  straightawayRate   Float
  oppoRate           Float
  sprintSpeed        Float
  computedAt         DateTime
  updatedAt          DateTime @updatedAt

  @@map("league_averages_snapshots")
}

// ─────────────────────────────────────────────────────────────────────────────
// pitcher_pitch_mix
// ─────────────────────────────────────────────────────────────────────────────

// Per-pitcher pitch-type usage and ball rates. Ingested by SavantDailyJob.
// One row per (pitcherId, season, pitchType); upserted on each daily run.
model PitcherPitchMix {
  id            Int    @id @default(autoincrement())
  pitcherId     Int
  pitcherName   String
  season        Int
  pitchType     String
  pitchTypeName String

  usageRate  Float
  ballRate   Float
  strikeRate Float?
  pitchCount Int

  fetchedAt DateTime
  updatedAt DateTime @updatedAt

  @@unique([pitcherId, season, pitchType])
  @@index([pitcherId, season])
  @@map("pitcher_pitch_mix")
}

// ─────────────────────────────────────────────────────────────────────────────
// game_lineups
// ─────────────────────────────────────────────────────────────────────────────

// Batting order from MLB live feed boxscore. Updated when the feed changes.
model GameLineup {
  id           Int      @id @default(autoincrement())
  gamePk       Int
  teamId       Int
  playerId     Int
  battingOrder Int
  fetchedAt    DateTime
  updatedAt    DateTime @updatedAt

  game Game @relation(fields: [gamePk], references: [gamePk])

  @@unique([gamePk, teamId, playerId])
  @@index([gamePk, teamId])
  @@map("game_lineups")
}

// ─────────────────────────────────────────────────────────────────────────────
// player_names
// ─────────────────────────────────────────────────────────────────────────────

// Canonical MLB player ID → display name, enriched over time from live feed,
// Savant daily jobs, and challenge review payloads.
model PlayerName {
  playerId  Int      @id
  fullName  String
  updatedAt DateTime @updatedAt

  @@map("player_names")
}

// ─────────────────────────────────────────────────────────────────────────────
// Rankings (precomputed incremental totals)
// ─────────────────────────────────────────────────────────────────────────────

// Idempotent queue entry — one row per pitch review or postgame audit applied.
model RankingsContribution {
  id          Int      @id @default(autoincrement())
  sourceType  String   // "pitch_review" | "postgame_audit"
  sourceId    Int
  gamePk      Int
  gameDate    String
  season      Int
  payloadJson Json
  createdAt   DateTime @default(now())

  @@unique([sourceType, sourceId])
  @@index([gamePk])
  @@index([gameDate])
  @@map("rankings_contributions")
}

model PlayerRankingDayBucket {
  id                   Int    @id @default(autoincrement())
  playerId             Int
  gameDate             String
  season               Int
  challengesUsed       Int    @default(0)
  challengesOverturned Int    @default(0)
  missedOpportunities  Int    @default(0)
  totalMissedValue     Float  @default(0)
  battingGainedRe      Float  @default(0)
  fieldingGainedRe     Float  @default(0)
  badChallenges        Int    @default(0)

  @@unique([playerId, gameDate, season])
  @@index([gameDate, season])
  @@map("player_ranking_day_buckets")
}

model TeamRankingDayBucket {
  id                   Int    @id @default(autoincrement())
  teamId               Int
  gameDate             String
  season               Int
  challengesUsed       Int    @default(0)
  challengesOverturned Int    @default(0)
  battingMissedCount   Int    @default(0)
  battingMissedValue   Float  @default(0)
  fieldingMissedCount  Int    @default(0)
  fieldingMissedValue  Float  @default(0)
  battingGainedRe      Float  @default(0)
  fieldingGainedRe     Float  @default(0)
  badChallenges        Int    @default(0)

  @@unique([teamId, gameDate, season])
  @@index([gameDate, season])
  @@map("team_ranking_day_buckets")
}

model PlayerRankingSeasonTotal {
  id                   Int    @id @default(autoincrement())
  playerId             Int
  season               Int
  challengesUsed       Int    @default(0)
  challengesOverturned Int    @default(0)
  missedOpportunities  Int    @default(0)
  totalMissedValue     Float  @default(0)
  battingGainedRe      Float  @default(0)
  fieldingGainedRe     Float  @default(0)
  badChallenges        Int    @default(0)

  @@unique([playerId, season])
  @@map("player_ranking_season_totals")
}

model TeamRankingSeasonTotal {
  id                   Int    @id @default(autoincrement())
  teamId               Int
  season               Int
  challengesUsed       Int    @default(0)
  challengesOverturned Int    @default(0)
  battingMissedCount   Int    @default(0)
  battingMissedValue   Float  @default(0)
  fieldingMissedCount  Int    @default(0)
  fieldingMissedValue  Float  @default(0)
  battingGainedRe      Float  @default(0)
  fieldingGainedRe     Float  @default(0)
  badChallenges        Int    @default(0)

  @@unique([teamId, season])
  @@map("team_ranking_season_totals")
}

model RankingPlayerGameAppearance {
  playerId Int
  gamePk   Int
  gameDate String
  season   Int

  @@id([playerId, gamePk])
  @@index([playerId, gameDate, season])
  @@map("ranking_player_game_appearances")
}

model RankingTeamGameAppearance {
  teamId   Int
  gamePk   Int
  gameDate String
  season   Int

  @@id([teamId, gamePk])
  @@index([teamId, gameDate, season])
  @@map("ranking_team_game_appearances")
}

